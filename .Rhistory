frq(data$a07_empl_sit)
frq(data$a07)
frq(data$b21)
frq(data$b25)
# Afiliado sindical = b21 in {1,2} (activo o inactivo).
# Afiliado independiente a sindicato/agrupamiento = b25 == 1.
data <- data %>%
mutate(
unionized = case_when(
b21 %in% c(1, 2) ~ 1,
b25 == 1         ~ 1,
.default = 0
)
) %>%
set_variable_labels(unionized = "Union member (Salaried or Self-employed; 1 = yes)") %>%
set_value_labels(unionized = c("Yes" = 1, "No" = 0))
frq(data$unionized)
frq(data$b19)
data <- data %>%
mutate(
b19_unionized_firm = case_when(
b19 == 1 ~ 1,
.default = 0
)
) %>%
set_variable_labels(b19_unionized_firm = "Union present in firm (1 = yes)") %>%
set_value_labels(b19_unionized_firm = c("Yes" = 1, "No" = 0))
frq(data$b19_unionized_firm)
frq(data$b23)
frq(data$b27)
# Económica = opción 1 en cualquiera de las dos fuentes.
# Colectivista = opción 2 en cualquiera de las dos fuentes.
data <- data %>%
mutate(
.econ = tiene_opcion(b23, 1) | tiene_opcion(b27, 1),
.coll = tiene_opcion(b23, 2) | tiene_opcion(b27, 2),
.resp_valida = !is.na(zap_labels(b23)) | !is.na(zap_labels(b27)),
b23_why_member = factor(
case_when(
.econ & !.coll ~ 1,
!.econ & .coll ~ 2,
.econ & .coll  ~ 3,
.resp_valida   ~ 4,   # eligió otras opciones (no económica/colectivista)
.default = NA_real_
),
levels = 1:4,
labels = c(
"Pure economic motivation",
"Pure collectivist motivation",
"Economic and collectivist motivations",
"Other"
)
)
) %>%
select(-starts_with(".")) %>%
set_variable_labels(b23_why_member = "Reason for union membership")
frq(data$b23_cat1)
frq(data$b27_cat1)
# Económica = cat1 en cualquiera de las dos fuentes (b23 o b27).
# Colectivista = cat2 en cualquiera de las dos fuentes.
# b23 tiene cat1–cat6; b27 tiene cat1–cat4.
data <- data %>%
mutate(
.econ = (b23_cat1 == 1) | (b27_cat1 == 1),
.coll = (b23_cat2 == 1) | (b27_cat2 == 1),
.resp_valida = respondio_multi(., "b23", 6) | respondio_multi(., "b27", 4),
b23_why_member = factor(
case_when(
.econ & !.coll ~ 1,
!.econ & .coll ~ 2,
.econ & .coll  ~ 3,
.resp_valida   ~ 4,   # eligió otras opciones (no económica/colectivista)
.default = NA_real_
),
levels = 1:4,
labels = c(
"Pure economic motivation",
"Pure collectivist motivation",
"Economic and collectivist motivations",
"Other"
)
)
) %>%
select(-starts_with(".")) %>%
set_variable_labels(b23_why_member = "Reason for union membership")
frq(data$b23_why_member)
# Económica = cat1 en cualquiera de las dos fuentes (b23 o b27).
# Colectivista = cat2 en cualquiera de las dos fuentes.
