) %>%
select(-starts_with(".")) %>%
set_variable_labels(b23_why_member = "Reason for union membership")
frq(data$b23_why_member)
frq(data$b24_cat1)
# b24 tiene cat1–cat8. Detección por grupo con dummies.
data <- data %>%
mutate(
.useful   = (b24_cat1 %in% 1) | (b24_cat5 == 1),
.work     = (b24_cat2 == 1) | (b24_cat3 == 1),
.distrust = (b24_cat4 == 1) | (b24_cat6 == 1) | (b24_cat7 == 1),
.ngrupos  = .useful + .work + .distrust,
b24_why_not_member = factor(
case_when(
.ngrupos == 1 & .useful   ~ 1,
.ngrupos == 1 & .work     ~ 2,
.ngrupos == 1 & .distrust ~ 3,
.ngrupos >= 2             ~ 4,   # Mixed
.default = NA_real_
),
levels = 1:4,
labels = c(
"Not useful",
"Work-related constraints",
"Don't trust union leaders",
"Mixed reasons"
)
)
) %>%
select(-starts_with(".")) %>%
set_variable_labels(b24_why_not_member = "Reason for not being a union member")
frq(data$b24_why_not_member)
frq(data$b24_cat1)
frq(data$b24_cat1)
# b24 tiene cat1–cat8. Detección por grupo con dummies.
data <- data %>%
mutate(
.useful   = (b24_cat1 == 1) | (b24_cat5 == 1),
.work     = (b24_cat2 == 1) | (b24_cat3 == 1),
.distrust = (b24_cat4 == 1) | (b24_cat6 == 1) | (b24_cat7 == 1),
.ngrupos  = .useful + .work + .distrust,
b24_why_not_member = factor(
case_when(
.ngrupos == 1 & .useful   ~ 1,
.ngrupos == 1 & .work     ~ 2,
.ngrupos == 1 & .distrust ~ 3,
.ngrupos >= 2             ~ 4,   # Mixed
.default = NA_real_
),
levels = 1:4,
labels = c(
"Not useful",
"Work-related constraints",
"Don't trust union leaders",
"Mixed reasons"
)
)
) %>%
select(-starts_with(".")) %>%
set_variable_labels(b24_why_not_member = "Reason for not being a union member")
frq(data$b24_why_not_member)
table(data$unionized, is.na(data$b23_why_member))
data %>%
filter(unionized == 1 & is.na(b23_why_member)) %>%
select(starts_with("b23_cat"), starts_with("b27_cat"))
